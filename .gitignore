.DS_Store

# IDE / editor
.idea/
.vscode/
*.iml

# Env / local config (never commit secrets)
**/.env
**/.env.*
!**/.env.example
**/application-local.properties

# Java / Maven
**/target/
**/*.class
**/.classpath
**/.project
**/.settings/

# Node / Vite
**/node_modules/
**/dist/
**/dist-ssr/
**/*.local

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

